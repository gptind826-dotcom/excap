<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base Application Theme -->
    <style name="Theme.EXcap" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary Colors -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@android:color/white</item>
        
        <!-- Secondary/Accent Colors -->
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSecondaryVariant">@color/accent_dark</item>
        <item name="colorOnSecondary">@android:color/black</item>
        
        <!-- Background Colors -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        
        <!-- Error -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@android:color/white</item>
        
        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        
        <!-- Text Colors -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        
        <!-- Card -->
        <item name="materialCardViewStyle">@style/Widget.EXcap.CardView</item>
        
        <!-- FAB -->
        <item name="floatingActionButtonStyle">@style/Widget.EXcap.FAB</item>
        
        <!-- Toolbar -->
        <item name="toolbarStyle">@style/Widget.EXcap.Toolbar</item>
        
        <!-- Navigation View -->
        <item name="navigationViewStyle">@style/Widget.EXcap.NavigationView</item>
    </style>

    <!-- Splash Theme -->
    <style name="Theme.EXcap.Splash" parent="Theme.EXcap">
        <item name="android:windowBackground">@drawable/splash_background</item>
    </style>

    <!-- App Bar Overlay -->
    <style name="Theme.EXcap.AppBarOverlay" parent="ThemeOverlay.Material3.Dark.ActionBar">
        <item name="android:background">@color/background</item>
    </style>

    <!-- Popup Overlay -->
    <style name="Theme.EXcap.PopupOverlay" parent="ThemeOverlay.Material3.Dark">
        <item name="android:background">@color/surface</item>
    </style>

    <!-- Custom Widget Styles -->
    <style name="Widget.EXcap.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/card_background</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
        <item name="strokeColor">@color/card_stroke</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.EXcap.FAB" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/accent</item>
        <item name="tint">@android:color/black</item>
        <item name="elevation">6dp</item>
    </style>

    <style name="Widget.EXcap.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/background</item>
        <item name="titleTextColor">@color/text_primary</item>
        <item name="subtitleTextColor">@color/text_secondary</item>
    </style>

    <style name="Widget.EXcap.NavigationView" parent="Widget.Material3.NavigationView">
        <item name="android:background">@color/surface</item>
        <item name="itemIconTint">@color/accent</item>
        <item name="itemTextColor">@color/text_primary</item>
        <item name="itemRippleColor">@color/ripple_color</item>
    </style>

</resources>
